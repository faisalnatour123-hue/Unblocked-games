{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the unblocked games site.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "description": "The user's profile picture URL." },
        "email": { "type": "string", "description": "The user's email address." },
        "role": { "type": "string", "description": "The user's role (e.g., 'user', 'admin')." },
        "createdAt": { "type": "timestamp", "description": "When the user account was created." }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "CustomTheme": {
      "title": "Custom Theme",
      "description": "A custom theme created by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the theme creator." },
        "bgMain": { "type": "string", "description": "Main background color." },
        "bgHeader": { "type": "string", "description": "Header background color." },
        "bgCard": { "type": "string", "description": "Card background color." },
        "bgAccent": { "type": "string", "description": "Accent background color." },
        "textHeader": { "type": "string", "description": "Header text color." },
        "textCard": { "type": "string", "description": "Card text color." },
        "bgImage": { "type": "string", "description": "Background image URL." },
        "updatedAt": { "type": "timestamp", "description": "When the theme was last updated." }
      },
      "required": ["uid", "bgMain", "bgHeader", "bgCard", "bgAccent", "textHeader", "textCard"]
    },
    "GameRating": {
      "title": "Game Rating",
      "description": "A rating given to a game by a user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user ID of the rater." },
        "gameId": { "type": "string", "description": "The ID of the game being rated." },
        "rating": { "type": "number", "description": "The rating value (e.g., 1 to 5)." },
        "updatedAt": { "type": "timestamp", "description": "When the rating was last updated." }
      },
      "required": ["uid", "gameId", "rating"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "Stores user profiles."
    },
    "customThemes/{userId}": {
      "schema": { "$ref": "CustomTheme" },
      "description": "Stores custom themes created by users."
    },
    "ratings/{ratingId}": {
      "schema": { "$ref": "GameRating" },
      "description": "Stores game ratings. ratingId is usually userId_gameId."
    }
  }
}
